# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_application_client_id_here

# Optional: Spotify Integration (for Spotify URL support)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Optional: Dashboard Configuration
DASHBOARD_PORT=3000

# Optional: YouTube Cookies (for bypassing age restrictions/rate limits)
# Place your cookies.txt file in the project root or set path below
# YOUTUBE_COOKIES_PATH=path/to/cookies.txt

# Optional: SoundCloud API (for SoundCloud support)
# SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id_here

# Optional: Debug Mode
DEBUG=false

# -----------------------------------------------------------------------------
# Lavalink Configuration (Required for Lavalink-based playback)
# -----------------------------------------------------------------------------
# The host or IP address of your Lavalink server.
LAVALINK_HOST=localhost
# The port your Lavalink server is listening on.
LAVALINK_PORT=2333
# The password for your Lavalink server.
LAVALINK_PASSWORD=youshallnotpass